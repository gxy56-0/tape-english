/* pages/typing/typing.wxss — Adaptive rpx sizing */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

/* === Word Area === */
.word-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx;
}

.word-zh {
  font-size: 64rpx;
  color: var(--text);
  font-weight: 600;
  text-align: center;
  min-height: 80rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.35), 0 0 32rpx rgba(160,180,220,0.2);
}

.word-jyut {
  font-size: 36rpx;
  color: var(--neon-purple);
  font-family: monospace;
  min-height: 52rpx;
  opacity: 0.75;
}

.word-frame {
  border: 2px solid var(--border-subtle);
  padding: 36rpx 64rpx;
  border-radius: 12rpx;
  transition: border-color 0.12s, box-shadow 0.12s;
}

.word-frame.correct-flash {
  border-color: var(--neon-green);
  box-shadow: 0 0 36rpx rgba(0,255,136,0.3);
}

.word-frame.wrong-flash {
  border-color: var(--neon-red);
  box-shadow: 0 0 28rpx rgba(255,51,102,0.3);
}

.word-display {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  font-size: 72rpx;
  font-family: monospace;
  letter-spacing: 6rpx;
  user-select: none;
}

.word-display.shake {
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-16rpx); }
  40% { transform: translateX(16rpx); }
  60% { transform: translateX(-12rpx); }
  80% { transform: translateX(8rpx); }
}

.letter {
  transition: color 0.1s;
}

.letter-normal { color: var(--text-muted); }
.letter-correct { color: var(--neon-green); text-shadow: 0 0 16rpx rgba(0,255,136,0.5); }
.letter-wrong   { color: var(--neon-red);   text-shadow: 0 0 16rpx rgba(255,51,102,0.5); }
.letter-space   { width: 0.45em; display: inline-block; }
.letter-skip    { color: var(--text-muted); opacity: 0.6; }

/* === Pronunciation buttons === */
.pronounce-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.pron-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-family: monospace;
  border: 1px solid var(--border-subtle);
  background: transparent;
  color: var(--text-muted);
  border-radius: 4rpx;
  letter-spacing: 2rpx;
}

/* === Progress bar === */
.progress-wrap {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto 32rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: var(--border-subtle);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
  transition: width 0.3s ease;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: monospace;
  margin-top: 12rpx;
}

/* === Stats bar === */
.stats-bar {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-top: 1px solid var(--border-subtle);
  background: var(--glass-bg);
  backdrop-filter: blur(10px);
}

.stat-item {
  text-align: center;
  padding: 20rpx 4rpx;
  border-left: 1px solid var(--border-subtle);
}
.stat-item:first-child { border-left: none; }

.stat-value { font-size: 36rpx; font-weight: 700; font-family: monospace; display: block; }
.c-cyan    { color: var(--neon-cyan);    text-shadow: 0 0 12rpx rgba(0,240,255,0.3); }
.c-magenta { color: var(--neon-magenta);  text-shadow: 0 0 12rpx rgba(255,0,229,0.3); }
.c-amber   { color: var(--neon-amber);   text-shadow: 0 0 12rpx rgba(255,184,0,0.3); }
.c-green   { color: var(--neon-green);   text-shadow: 0 0 12rpx rgba(0,255,136,0.3); }
.c-purple  { color: var(--neon-purple);  text-shadow: 0 0 12rpx rgba(168,85,247,0.3); }

.stat-label {
  font-size: 18rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-family: monospace;
  margin-top: 4rpx;
}

/* === Transparent input overlay === */
.input-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: auto;
}

.typing-input {
  width: 100%;
  height: 100%;
  opacity: 0;
}
