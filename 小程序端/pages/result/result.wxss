/* pages/result/result.wxss — Adaptive rpx sizing */

.page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--bg);
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.result-card {
  background: var(--surface);
  border: 1px solid var(--border-subtle);
  padding: 80rpx 64rpx;
  max-width: 640rpx;
  width: 100%;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--neon-cyan);
  text-shadow: 0 0 20rpx rgba(0,240,255,0.3);
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 16rpx;
}

.star-rating {
  font-size: 72rpx;
  letter-spacing: 12rpx;
  margin-bottom: 8rpx;
}

.star-filled {
  color: var(--neon-amber);
  text-shadow: 0 0 24rpx rgba(255,184,0,0.5);
  animation: starPop 0.4s cubic-bezier(0.34,1.56,0.64,1) backwards;
}
.star-filled:nth-child(1) { animation-delay: 0.1s; }
.star-filled:nth-child(2) { animation-delay: 0.25s; }
.star-filled:nth-child(3) { animation-delay: 0.4s; }

.star-empty { color: var(--border-subtle); }

@keyframes starPop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.star-label {
  font-size: 22rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 3rpx;
  font-family: monospace;
  margin-bottom: 28rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-bottom: 40rpx;
}

.rs-item { text-align: center; }

.rs-val {
  font-size: 80rpx;
  font-weight: 700;
  font-family: monospace;
  display: block;
}

.rs-lbl {
  font-size: 22rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 3rpx;
  font-family: monospace;
  margin-top: 8rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  margin-bottom: 40rpx;
  background: var(--border-subtle);
}

.dg-item {
  background: var(--bg);
  padding: 28rpx 16rpx;
}

.dg-val {
  font-size: 34rpx;
  font-weight: 700;
  font-family: monospace;
  color: var(--text);
  display: block;
}

.dg-lbl {
  font-size: 20rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-family: monospace;
  margin-top: 4rpx;
}

.history {
  margin-top: 32rpx;
  border-top: 1px solid var(--border-subtle);
  padding-top: 28rpx;
}

.history-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  font-family: monospace;
  text-align: center;
  margin-bottom: 20rpx;
  display: block;
}

.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 22rpx;
  font-family: monospace;
  color: var(--text-muted);
}

.h-date { flex: 0 0 130rpx; }
.h-stars { flex: 0 0 120rpx; text-align: center; }
.h-wpm { flex: 0 0 120rpx; text-align: right; color: var(--neon-cyan); }
.h-acc { flex: 0 0 100rpx; text-align: right; color: var(--neon-green); }

.history-empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 22rpx;
  font-family: monospace;
  padding: 16rpx 0;
}

.result-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 40rpx;
}

.btn {
  padding: 24rpx 56rpx;
  font-size: 26rpx;
  font-weight: 700;
  font-family: monospace;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  border: 1px solid var(--border-subtle);
  background: var(--surface);
  color: var(--text);
  border-radius: 4rpx;
}

.btn-primary {
  border-color: var(--neon-cyan);
  color: var(--neon-cyan);
}
