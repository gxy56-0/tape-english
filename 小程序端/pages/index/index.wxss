/* pages/index/index.wxss — Adaptive rpx sizing */

.page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--bg, #08081a);
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.count-card {
  background: var(--surface, #10102a);
  border: 1px solid var(--border-subtle, #252550);
  padding: 80rpx 64rpx;
  width: 100%;
  max-width: 640rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--neon-cyan);
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: monospace;
  margin-top: 16rpx;
  margin-bottom: 56rpx;
  display: block;
}

.count-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.count-opt {
  padding: 28rpx 16rpx;
  border: 1px solid var(--border-subtle);
  color: var(--text);
  font-size: 36rpx;
  font-weight: 700;
  font-family: monospace;
  transition: all 0.2s;
}

.count-opt.active {
  border-color: var(--neon-cyan);
  background: rgba(0, 240, 255, 0.08);
  color: var(--neon-cyan);
}

.custom-wrap {
  margin-bottom: 32rpx;
}

.custom-input {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 1px solid var(--border-subtle);
  background: var(--bg);
  color: var(--neon-cyan);
  font-size: 40rpx;
  font-family: monospace;
  text-align: center;
}

.theme-info {
  margin-bottom: 40rpx;
  font-family: monospace;
}

.theme-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.theme-val {
  font-size: 22rpx;
  color: var(--neon-cyan);
  font-weight: 700;
}

.theme-hint {
  font-size: 20rpx;
  color: var(--text-muted);
}

.btn-start {
  padding: 28rpx 96rpx;
  border: 1px solid var(--neon-cyan);
  background: rgba(0, 240, 255, 0.08);
  color: var(--neon-cyan);
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  font-family: monospace;
  border-radius: 4rpx;
}
